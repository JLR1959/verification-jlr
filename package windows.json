{
  "name": "vpijlr",
  "version": "1.0.0",
  "description": "Application Vérification Préventive Immobilière Jean-Louis Raymond",
  "main": "main.js",
  "author": "Jean-Louis Raymond",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "devDependencies": {
    "electron": "^28.2.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.vpijlr.app",
    "productName": "VPIJLR",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*"
    ],
    "win": {
      "target": ["nsis"],
      "icon": "icon.ico"
    },
    "linux": {
      "target": ["AppImage"],
      "icon": "icon.png"
    }
  }
}
